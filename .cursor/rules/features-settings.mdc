## Notification Settings

### Available Toggles
```dart
class NotificationSettings {
  bool petBirthdayReminders;
  bool dewormingReminders;
  bool vetCheckupReminders;
  bool communityActivity;
  bool newFollowers;
  bool postLikes;

  NotificationSettings({
    this.petBirthdayReminders = true,
    this.dewormingReminders = true,
    this.vetCheckupReminders = true,
    this.communityActivity = false,
    this.newFollowers = false,
    this.postLikes = false,
  });

  Map<String, dynamic> toJson() {
    return {
      'petBirthdayReminders': petBirthdayReminders,
      'dewormingReminders': dewormingReminders,
      'vetCheckupReminders': vetCheckupReminders,
      'communityActivity': communityActivity,
      'newFollowers': newFollowers,
      'postLikes': postLikes,
    };
  }

  factory NotificationSettings.fromJson(Map<String, dynamic> json) {
    return NotificationSettings(
      petBirthdayReminders: json['petBirthdayReminders'] ?? true,
      dewormingReminders: json['dewormingReminders'] ?? true,
      vetCheckupReminders: json['vetCheckupReminders'] ?? true,
      communityActivity: json['communityActivity'] ?? false,
      newFollowers: json['newFollowers'] ?? false,
      postLikes: json['postLikes'] ?? false,
    );
  }
}
```

## Theme Management

### Settings Repository
```dart
// lib/data/repositories/settings_repository.dart
class SettingsRepository {
  final LocalStorageService _storage;

  Future<bool> isDarkMode() async {
    return await _storage.getBool(StorageKeys.isDarkMode) ?? false;
  }

  Future<void> setDarkMode(bool value) async {
    await _storage.setBool(StorageKeys.isDarkMode, value);
  }

  Future<NotificationSettings> getNotificationSettings() async {
    final json = await _storage.getString(StorageKeys.notificationSettings);
    if (json != null) {
      return NotificationSettings.fromJson(jsonDecode(json));
    }
    return NotificationSettings();
  }

  Future<void> saveNotificationSettings(NotificationSettings settings) async {
    await _storage.setString(
      StorageKeys.notificationSettings,
      jsonEncode(settings.toJson()),
    );
  }
}
```

### Theme State Management
```dart
// In main.dart
class _MyAppState extends State<MyApp> {
  bool _isDarkMode = false;

  @override
  void initState() {
    super.initState();
    _loadThemePreference();
  }

  Future<void> _loadThemePreference() async {
    final prefs = await SharedPreferences.getInstance();
    setState(() {
      _isDarkMode = prefs.getBool(StorageKeys.isDarkMode) ?? false;
    });
  }

  void _toggleTheme(bool isDark) async {
    setState(() {
      _isDarkMode = isDark;
    });
    final prefs = await SharedPreferences.getInstance();
    await prefs.setBool(StorageKeys.isDarkMode, isDark);
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      theme: AppTheme.lightTheme,
      darkTheme: AppTheme.darkTheme,
      themeMode: _isDarkMode ? ThemeMode.dark : ThemeMode.light,
      // Pass _toggleTheme callback down to SettingsScreen
      home: MainScreen(onThemeToggle: _toggleTheme),
    );
  }
}
```

## Data Export

### Export Growth Track
```dart
Future<void> exportGrowthTrack(String petId) async {
  final pet = await _petRepository.getPetById(petId);
  final tracks = await _petRepository.getGrowthTracksForPet(petId);
  
  final exportData = {
    'pet': pet?.toJson(),
    'growthTracks': tracks.map((t) => t.toJson()).toList(),
    'exportedAt': DateTime.now().toIso8601String(),
  };
  
  final jsonString = jsonEncode(exportData);
  
  // Use share dialog to save/share file
  // For demo, show dialog with JSON preview
  showDialog(
    context: context,
    builder: (context) => AlertDialog(
      title: Text('Export Data'),
      content: SingleChildScrollView(
        child: Text(jsonString),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.pop(context),
          child: Text('Close'),
        ),
      ],
    ),
  );
}
```

## UI Specifications

### User Profile Section
- Avatar: 80px diameter, circular
- Name: 24px, bold
- Email: 14px, mediumGray
- Spacing: 16px between avatar and text
- Margin: 32px bottom

### Settings Tile
- Height: auto (min 56px)
- Border radius: 12px
