## Card System

### Card Model
```dart
class CardModel {
  final int id;           // Unique identifier
  final String iconName;  // FontAwesome icon name
  final Color color;      // Card color
  bool isFlipped;         // Currently showing front?
  bool isMatched;         // Successfully matched?
  
  CardModel({
    required this.id,
    required this.iconName,
    required this.color,
    this.isFlipped = false,
    this.isMatched = false,
  });
  
  CardModel copyWith({
    bool? isFlipped,
    bool? isMatched,
  }) {
    return CardModel(
      id: id,
      iconName: iconName,
      color: color,
      isFlipped: isFlipped ?? this.isFlipped,
      isMatched: isMatched ?? this.isMatched,
    );
  }
}
```

