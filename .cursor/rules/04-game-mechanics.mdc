### 3. Card Flip Logic
```dart
void onCardTap(CardModel card) {
  // Check conditions:
  if (isLocked) return;           // Animation in progress
  if (card.isMatched) return;     // Already matched
  if (card.isFlipped) return;     // Already flipped
  if (flippedCards.length >= 2) return; // Two cards already showing
  
  // Flip the card
  setState(() {
    card.isFlipped = true;
    flippedCards.add(card);
  });
  
  // Haptic feedback
  HapticFeedback.lightImpact();
  
  // If two cards flipped, check match
  if (flippedCards.length == 2) {
    incrementMoves();
    checkMatch();
  }
}
```

### 4. Match Checking
```dart
void checkMatch() {
  isLocked = true; // Prevent rapid tapping
  
  final card1 = flippedCards[0];
  final card2 = flippedCards[1];
  
  if (card1.iconName == card2.iconName) {
    // MATCH!
    handleMatch(card1, card2);
  } else {
    // MISMATCH
    handleMismatch(card1, card2);
  }
}

void handleMatch(CardModel card1, CardModel card2) {
  comboStreak++;
  matchedPairs++;
  
  // Calculate and add score
  int points = ScoringRules.calculateMatchScore(comboStreak);
  score += points;
  
  // Show combo indicator if streak > 1
  if (comboStreak > 1) {
    showComboUI(comboStreak);
  }
  
  // Success haptic
  HapticFeedback.mediumImpact();
  
  // After animation delay
  Future.delayed(Duration(milliseconds: 500), () {
    setState(() {
      card1.isMatched = true;
      card2.isMatched = true;
      flippedCards.clear();
      isLocked = false;
    });
    
    // Check win condition
    if (matchedPairs == totalPairs) {
      handleWin();
    }
  });
}

void handleMismatch(CardModel card1, CardModel card2) {
  comboStreak = 0; // Break combo
  
  // Error haptic
  HapticFeedback.heavyImpact();
  
  // Flip back after delay
  Future.delayed(Duration(milliseconds: 1000), () {
    setState(() {
      card1.isFlipped = false;
      card2.isFlipped = false;
      flippedCards.clear();
      isLocked = false;
    });
  });
}
```

### 5. Timer Logic
```dart
Timer? _gameTimer;

void startTimer() {
  _gameTimer = Timer.periodic(Duration(seconds: 1), (timer) {
    if (!isPaused) {
      setState(() {
        timeLeft--;
        
        if (timeLeft <= 0) {
          timer.cancel();
          handleLoss();
        }
      });
    }
  });
}

@override
void dispose() {
  _gameTimer?.cancel();
  super.dispose();
}
```

### 6. Win/Loss Conditions
```dart
void handleWin() {
  _gameTimer?.cancel();
  
  int stars = StarRating.calculateStars(timeLeft, totalTime);
  int finalScore = ScoringRules.calculateFinalScore(score, timeLeft);
  
  // Save to local storage
  LocalStorage.saveLevelResult(
    levelId: currentLevel,
    stars: stars,
    score: finalScore,
  );
  
  // Show result modal
  showResultModal(isWin: true, stars: stars);
}

void handleLoss() {
  _gameTimer?.cancel();
  showResultModal(isWin: false, stars: 0);
}
```

## Edge Cases to Handle

1. **Rapid Tapping**: Use `isLocked` flag during animations
2. **Pause During Animation**: Store animation state
3. **App Backgrounding**: Pause timer automatically
4. **Timer Synchronization**: Ensure timer updates don't conflict with game logic
5. **Memory Management**: Dispose timers and controllers properly
