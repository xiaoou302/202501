### 2. TimerBar - Animated Progress Bar
```dart
// lib/presentation/widgets/timer_bar.dart

class TimerBar extends StatelessWidget {
  final int timeLeft;
  final int totalTime;
  
  const TimerBar({
    Key? key,
    required this.timeLeft,
    required this.totalTime,
  }) : super(key: key);
  
  @override
  Widget build(BuildContext context) {
    final percentage = (timeLeft / totalTime).clamp(0.0, 1.0);
    final isLowTime = percentage < 0.3;
    
    return Column(
      children: [
        _buildHeader(isLowTime),
        const SizedBox(height: 8),
        _buildProgressBar(context, percentage, isLowTime),
      ],
    );
  }
  
  Widget _buildHeader(bool isLowTime) {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: [
        Text(
          'SYNC STABILITY',
          style: AppTextStyles.label.copyWith(
            color: isLowTime ? AppColors.danger : AppColors.mint,
          ),
        ),
        Text(
          '${timeLeft}s',
          style: AppTextStyles.label.copyWith(
            color: isLowTime ? AppColors.danger : AppColors.mint,
          ),
        ),
      ],
    );
  }
  
  Widget _buildProgressBar(
    BuildContext context,
    double percentage,
    bool isLowTime,
  ) {
    return Container(
      height: 8,
      decoration: BoxDecoration(
        color: AppColors.slate,
        borderRadius: BorderRadius.circular(4),
      ),
      child: AnimatedContainer(
        duration: const Duration(seconds: 1),
        curve: Curves.linear,
        width: MediaQuery.of(context).size.width * percentage * 0.85,
        decoration: BoxDecoration(
          gradient: isLowTime
              ? null
              : const LinearGradient(
                  colors: [AppColors.mint, AppColors.electric],
                ),
          color: isLowTime ? AppColors.danger : null,
          borderRadius: BorderRadius.circular(4),
        ),
      ),
    );
  }
}
```

### 3. HudWidget - Game Stats Display
```dart
// lib/presentation/widgets/hud_widget.dart

class HudWidget extends StatelessWidget {
  final int levelId;
  final int pairs;
  final int matchedPairs;
  final int moves;
  final int score;
  final int timeLeft;
  final int totalTime;
  final VoidCallback onPause;
  
  const HudWidget({
    Key? key,
    required this.levelId,
    required this.pairs,
    required this.matchedPairs,
    required this.moves,
    required this.score,
    required this.timeLeft,
    required this.totalTime,
    required this.onPause,
  }) : super(key: key);
  
  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.only(
        top: 56, // Account for status bar
        left: 24,
        right: 24,
        bottom: 16,
      ),
      decoration: BoxDecoration(
        gradient: LinearGradient(
          begin: Alignment.topCenter,
          end: Alignment.bottomCenter,
          colors: [
            AppColors.midnight,
            AppColors.midnight.withOpacity(0),
          ],
        ),
      ),
      child: Column(
        children: [
          _buildTopRow(),
          const SizedBox(height: 16),
          TimerBar(timeLeft: timeLeft, totalTime: totalTime),
        ],
      ),
    );
  }
  
  Widget _buildTopRow() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      crossAxisAlignment: CrossAxisAlignment.end,
      children: [
        _buildLevelDisplay(),
        const Spacer(),
        _buildPauseButton(),
      ],
    );
  }
  
  Widget _buildLevelDisplay() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          'SECTOR',
          style: AppTextStyles.label,
        ),
        Text(
          'LVL ${levelId.toString().padLeft(2, '0')}',
          style: AppTextStyles.h2,
        ),
      ],
    );
  }
  
  Widget _buildPauseButton() {
    return GestureDetector(
      onTap: onPause,
      child: Container(
        width: 40,
        height: 40,
        decoration: BoxDecoration(
          color: AppColors.slate,
          borderRadius: BorderRadius.circular(20),
        ),
        child: const Icon(
          Icons.pause,
          color: AppColors.mica,
          size: 20,
        ),
      ),
    );
  }
}
